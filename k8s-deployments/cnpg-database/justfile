name           := "main-db"
wasm_name      := "cnpg-database"
deployment_dir := source_directory()
default_flags  := "-namespace main-db -force-conflicts"

import '../shared_yoke.just'

# Build and deploy the restore cluster to the cluster
takeoff-restore extra_flags="": _maybe_seal
    #!/usr/bin/env bash
    set -euo pipefail
    cargo build --target=wasm32-wasip1 --release
    if [ -f "{{sealed_secrets_file}}" ]; then
        yoke takeoff {{default_flags}} {{extra_flags}} {{name}}-restore {{source_directory()}}/target/wasm32-wasip1/release/{{wasm_name}}.wasm < {{sealed_secrets_file}} -- --restore
    else
        yoke takeoff {{default_flags}} {{extra_flags}} {{name}}-restore {{source_directory()}}/target/wasm32-wasip1/release/{{wasm_name}}.wasm -- --restore
    fi

# Build and print rendered restore cluster manifests to stdout without deploying
debug-restore extra_flags="": _maybe_seal
    #!/usr/bin/env bash
    set -euo pipefail
    cargo build --target=wasm32-wasip1
    if [ -f "{{sealed_secrets_file}}" ]; then
        yoke takeoff -stdout {{default_flags}} {{extra_flags}} {{name}}-restore {{source_directory()}}/target/wasm32-wasip1/debug/{{wasm_name}}.wasm < {{sealed_secrets_file}} -- --restore
    else
        yoke takeoff -stdout {{default_flags}} {{extra_flags}} {{name}}-restore {{source_directory()}}/target/wasm32-wasip1/debug/{{wasm_name}}.wasm -- --restore
    fi

# Build and show a diff of restore cluster changes without deploying
diff-restore extra_flags="": _maybe_seal
    #!/usr/bin/env bash
    set -euo pipefail
    cargo build --target=wasm32-wasip1
    if [ -f "{{sealed_secrets_file}}" ]; then
        yoke takeoff -diff-only {{default_flags}} {{extra_flags}} {{name}}-restore {{source_directory()}}/target/wasm32-wasip1/debug/{{wasm_name}}.wasm < {{sealed_secrets_file}} -- --restore
    else
        yoke takeoff -diff-only {{default_flags}} {{extra_flags}} {{name}}-restore {{source_directory()}}/target/wasm32-wasip1/debug/{{wasm_name}}.wasm -- --restore
    fi
