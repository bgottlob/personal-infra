use flake

export TOFU_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/tofu"

dotenv_if_exists .env

use_sops() {
    local path="${SECRETS_FILE}"
    if [[ -z "$path" ]]; then
        echo $'\e[31mdirenv: error: SECRETS_FILE is not set. Add SECRETS_FILE=/path/to/secrets.yaml to your .env file.\e[0m' >&2
        return 1
    fi
    if [[ ! -f "$path" ]]; then
        echo $'\e[31mdirenv: error: SECRETS_FILE points to '"'$path'"', but that file does not exist.\e[0m' >&2
        return 1
    fi
    local secrets_yaml=$(sops -d --output-type yaml "$path")

    export AWS_ACCESS_KEY_ID=$(echo "${secrets_yaml}" | yq -r ".linode.access_key_id")
    export AWS_SECRET_ACCESS_KEY=$(echo "${secrets_yaml}" | yq -r ".linode.secret_access_key")

    watch_file "$path"
}

use sops

export TF_VAR_s3_access_key="${AWS_ACCESS_KEY_ID}"
export TF_VAR_s3_secret_key="${AWS_SECRET_ACCESS_KEY}"
export TF_VAR_secrets_file="${SECRETS_FILE}"

# For using kubectl commands
export KUBECONFIG="${HOME}/.kube/config"
# For the helm provider
export KUBE_CONFIG_PATH="${HOME}/.kube/config"
